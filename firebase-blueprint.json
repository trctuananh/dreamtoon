{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The name of the user." },
        "handle": { "type": "string", "description": "The unique handle of the user (e.g., @username)." },
        "email": { "type": "string", "description": "The email of the user.", "format": "email" },
        "photoURL": { "type": "string", "description": "The profile picture URL of the user." },
        "role": { "type": "string", "description": "The role of the user (e.g., 'dreamer', 'admin').", "enum": ["dreamer", "admin"] },
        "bio": { "type": "string", "description": "The biography of the user." },
        "donateInfo": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "imageUrl": { "type": "string" }
          }
        },
        "commissionInfo": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "imageUrl": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Comic": {
      "title": "Comic Series",
      "description": "Information about a webtoon series.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the comic." },
        "title": { "type": "string", "description": "The title of the comic." },
        "description": { "type": "string", "description": "A brief description of the comic." },
        "thumbnail": { "type": "string", "description": "The thumbnail image URL." },
        "banner": { "type": "string", "description": "The banner image URL." },
        "genre": { "type": "array", "items": { "type": "string" }, "description": "The genres of the comic." },
        "views": { "type": "number", "description": "The total number of views." },
        "rating": { "type": "number", "description": "The average rating." },
        "ratingCount": { "type": "number", "description": "The total number of ratings." },
        "authorUid": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "title", "authorUid"]
    },
    "Chapter": {
      "title": "Comic Chapter",
      "description": "A single chapter of a comic series.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the chapter." },
        "comicId": { "type": "string", "description": "The ID of the parent comic." },
        "authorUid": { "type": "string", "description": "The UID of the author." },
        "title": { "type": "string", "description": "The title of the chapter." },
        "number": { "type": "number", "description": "The chapter number." },
        "uploadDate": { "type": "string", "description": "The date the chapter was uploaded." },
        "images": { "type": "array", "items": { "type": "string" }, "description": "The list of image URLs for the chapter." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "comicId", "number", "images"]
    },
    "Comment": {
      "title": "Chapter Comment",
      "description": "A comment left by a user on a chapter.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the comment." },
        "userId": { "type": "string", "description": "The UID of the user who commented." },
        "userName": { "type": "string", "description": "The name of the user." },
        "userPhoto": { "type": "string", "description": "The profile picture URL of the user." },
        "chapterId": { "type": "string", "description": "The ID of the chapter." },
        "comicId": { "type": "string", "description": "The ID of the comic." },
        "text": { "type": "string", "description": "The content of the comment." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "userId", "chapterId", "comicId", "text"]
    },
    "Like": {
      "title": "Chapter Like",
      "description": "A like given by a user to a chapter.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the like." },
        "userId": { "type": "string", "description": "The UID of the user who liked." },
        "chapterId": { "type": "string", "description": "The ID of the chapter." },
        "comicId": { "type": "string", "description": "The ID of the comic." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "userId", "chapterId", "comicId"]
    },
    "Rating": {
      "title": "Comic Rating",
      "description": "A rating given by a user to a comic series.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the rating (usually comicId_userId)." },
        "userId": { "type": "string", "description": "The UID of the user who rated." },
        "comicId": { "type": "string", "description": "The ID of the comic." },
        "score": { "type": "number", "description": "The rating score (1-5)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "userId", "comicId", "score"]
    },
    "Following": {
      "title": "Following",
      "description": "A record of a user following an artist or a comic series.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the following record." },
        "userId": { "type": "string", "description": "The UID of the user who is following." },
        "targetId": { "type": "string", "description": "The ID of the target artist or comic." },
        "type": { "type": "string", "description": "The type of the target (e.g., 'artist', 'comic').", "enum": ["artist", "comic"] },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "userId", "targetId", "type"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post created by a user on their wall or in the community.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the post." },
        "authorUid": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "authorPhoto": { "type": "string", "description": "The profile picture URL of the author." },
        "content": { "type": "string", "description": "The content of the post." },
        "imageUrl": { "type": "string", "description": "The URL of an image attached to the post." },
        "type": { "type": "string", "description": "The type of the post.", "enum": ["twit", "sketch", "donate", "commission"] },
        "likes": { "type": "number", "description": "The number of likes." },
        "comments": { "type": "number", "description": "The number of comments." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "authorUid", "content", "type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the notification." },
        "recipientId": { "type": "string", "description": "The UID of the user receiving the notification." },
        "senderId": { "type": "string", "description": "The UID of the user who triggered the notification." },
        "senderName": { "type": "string", "description": "The name of the sender." },
        "senderPhoto": { "type": "string", "description": "The profile picture URL of the sender." },
        "type": { "type": "string", "description": "The type of notification.", "enum": ["like", "comment", "follow", "new_chapter"] },
        "targetId": { "type": "string", "description": "The ID of the related content (post, comic, etc.)." },
        "targetTitle": { "type": "string", "description": "The title of the related content." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "recipientId", "senderId", "type", "read"]
    },
    "Donation": {
      "title": "Donation Message",
      "description": "A message left by a user after donating to an artist.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the donation record." },
        "artistUid": { "type": "string", "description": "The UID of the artist who received the donation." },
        "donorUid": { "type": "string", "description": "The UID of the donor (optional)." },
        "donorName": { "type": "string", "description": "The name of the donor." },
        "message": { "type": "string", "description": "The support message." },
        "amount": { "type": "number", "description": "The donation amount (optional)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date." }
      },
      "required": ["id", "artistUid", "donorName", "message"]
    },
    "CommissionWork": {
      "title": "Commission Work Progress",
      "description": "A record of a commission's progress.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the work record." },
        "artistUid": { "type": "string", "description": "The UID of the artist." },
        "title": { "type": "string", "description": "The title of the commission work." },
        "clientName": { "type": "string", "description": "The name of the client." },
        "status": { "type": "string", "description": "The current status (e.g., 'Sketching')." },
        "progress": { "type": "number", "description": "Progress percentage (0-100)." },
        "order": { "type": "number", "description": "Display order." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update date." }
      },
      "required": ["id", "artistUid", "title", "status", "progress"]
    },
    "Profile": {
      "title": "Public Profile",
      "description": "Publicly accessible information about a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The name of the user." },
        "handle": { "type": "string", "description": "The unique handle of the user." },
        "photoURL": { "type": "string", "description": "The profile picture URL." },
        "bio": { "type": "string", "description": "The biography of the user." },
        "role": { "type": "string", "description": "The role of the user." },
        "donateInfo": { "type": "object" },
        "commissionInfo": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "The collection of user profiles."
    },
    "/profiles/{uid}": {
      "schema": "Profile",
      "description": "Publicly accessible user profiles."
    },
    "/users/{uid}/following/{id}": {
      "schema": "Following",
      "description": "The subcollection of following records for a specific user."
    },
    "/users/{uid}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "The subcollection of notifications for a specific user."
    },
    "/users/{uid}/commissions/{id}": {
      "schema": "CommissionWork",
      "description": "The subcollection of commission work progress for an artist."
    },
    "/comics/{comicId}": {
      "schema": "Comic",
      "description": "The collection of comic series."
    },
    "/comics/{comicId}/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "The subcollection of chapters for a specific comic."
    },
    "/comics/{comicId}/chapters/{chapterId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "The subcollection of comments for a specific chapter."
    },
    "/comics/{comicId}/chapters/{chapterId}/likes/{likeId}": {
      "schema": "Like",
      "description": "The subcollection of likes for a specific chapter."
    },
    "/comics/{comicId}/ratings/{userId}": {
      "schema": "Rating",
      "description": "The subcollection of ratings for a specific comic."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "The collection of community posts."
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "The collection of donation messages."
    }
  }
}
